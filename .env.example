# n8n configuration — copy to .env and fill in real values.
#
# CRITICAL: Once N8N_ENCRYPTION_KEY is set and n8n has run once, DO NOT
# CHANGE IT. All stored credentials (Telegram tokens, Meta tokens, future
# Anthropic key, etc.) are encrypted with this key and become unrecoverable
# if it changes. Back up this .env file immediately to a secure location
# (1Password, encrypted note) after first run.

# ───────────────────────────────────────────────────────────────────
# Secrets — generate locally, never commit
# ───────────────────────────────────────────────────────────────────

# 64 hex chars (32 bytes).  openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# ───────────────────────────────────────────────────────────────────
# URL / host
# ───────────────────────────────────────────────────────────────────
#
# WEBHOOK_URL is the public URL n8n bakes into webhook + form links it
# generates (e.g. the "Review:" form URL the workflow puts in Telegram).
# If this is wrong, those links point at localhost and your phone can't
# open them.
#
# Three deployment shapes:
#
# 1. LOCAL only, no external triggers needed
#    N8N_HOST=localhost
#    N8N_PROTOCOL=http
#    WEBHOOK_URL=http://localhost:5678
#
# 2. LOCAL + ngrok tunnel (current dev setup for the approval-gate flow)
#    Start the tunnel:  ngrok http 5678
#    (or with a claimed static domain: ngrok http 5678 --url=<your>.ngrok-free.app)
#    Then set:
#      N8N_HOST=<your-random-or-static>.ngrok-free.app
#      N8N_PROTOCOL=https
#      WEBHOOK_URL=https://<your-random-or-static>.ngrok-free.app
#    Restart the n8n container after changing these.
#
# 3. PRODUCTION (server with real domain)
#    N8N_HOST=agent.lorentbloom.com
#    N8N_PROTOCOL=https
#    WEBHOOK_URL=https://agent.lorentbloom.com
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# ───────────────────────────────────────────────────────────────────
# Timezone
# ───────────────────────────────────────────────────────────────────

# Used by Schedule / Cron triggers so "every day at 9am" means the right
# 9am. List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
GENERIC_TIMEZONE=Europe/Chisinau

# ───────────────────────────────────────────────────────────────────
# Workflow config — read at runtime via $env.NAME in workflow expressions.
# Restart n8n after changing any of these.
# ───────────────────────────────────────────────────────────────────

# Telegram bot token (from @BotFather → /mybots → API Token).
# Used by the Send preview HTTP node which posts directly to Telegram API.
TELEGRAM_BOT_TOKEN=

# Numeric chat ID where previews land. For yourself, message @userinfobot
# in Telegram to get your ID. For a group, add the bot then check
# https://api.telegram.org/bot<TOKEN>/getUpdates after sending a message.
TELEGRAM_CHAT_ID=

# Cloudflare account ID for the Workers AI Flux Schnell image generation
# endpoint. Find it in the Cloudflare dashboard URL after you log in.
CLOUDFLARE_ACCOUNT_ID=

# Facebook Page ID (the "Lorent Bloom" page). Find via Token Debugger or
# /me/accounts on Graph API Explorer.
FB_PAGE_ID=

# Instagram Business Account ID, linked to the FB Page above. Format:
# starts with 17841...
IG_BUSINESS_ACCOUNT_ID=
