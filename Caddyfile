# Caddy reverse proxy for n8n.
#
# Reads N8N_HOST from the container environment (set in docker-compose.yml,
# sourced from .env). For agent.example.com, N8N_HOST=agent.example.com.
#
# Caddy automatically:
#   - Fetches a Let's Encrypt cert for {$N8N_HOST} on first request
#   - Renews it (default 30 days before expiry)
#   - Redirects HTTP → HTTPS
#
# Stores cert state in /data (mapped to caddy_data volume — DO NOT lose
# this volume or you'll re-issue certs and may hit Let's Encrypt rate
# limits on repeated boots).

{$N8N_HOST} {
	# n8n's Telegram + Wait webhooks can carry large payloads (photos etc.).
	# Default Caddy body limit is 10 MB; bump comfortably.
	request_body {
		max_size 50MB
	}

	encode zstd gzip

	reverse_proxy n8n:5678 {
		# Forward the original scheme + host so n8n's $execution.resumeUrl
		# uses https://agent.example.com instead of the internal Docker hostname.
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
}
